<%- include('../../partials/head', { title: title }) %>
<%- include('../../partials/navbar', { user }) %>
<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Peserta</h3>
    <a href="/admin/peserta/tambah" class="btn btn-primary">+ Tambah Peserta</a>
  </div>

  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
  <% if (info) { %><div class="alert alert-success"><%= info %></div><% } %>

  <form method="get" action="/admin/peserta" class="row g-2 mb-3">
    <div class="col-auto">
      <input type="text" name="q" class="form-control" placeholder="Cari nama/no. HP" value="<%= filter.q %>">
    </div>
    <div class="col-auto">
      <select name="sesi_id" class="form-select">
        <option value="">Semua sesi</option>
        <% sesiList.forEach(s => { %>
          <option value="<%= s.id %>" <%= String(filter.sesi_id) === String(s.id) ? 'selected' : '' %>><%= s.nama %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-auto"><button class="btn btn-outline-secondary" type="submit">Filter</button></div>
    <div class="col-auto"><a class="btn btn-outline-success" href="/admin/peserta/export?sesi_id=<%= filter.sesi_id %>">Export CSV</a></div>
  </form>

  <div class="card mb-3">
    <div class="card-body">
      <h6>Impor Peserta (CSV)</h6>
      <p class="text-muted small mb-2">Kolom: nama, no_hp, email, institusi, sesi (nama sesi dipisah koma jika lebih dari satu).</p>
      <form method="post" action="/admin/peserta/import" enctype="multipart/form-data" class="d-flex gap-2">
        <input type="file" name="file" accept=".csv" class="form-control" required>
        <button type="submit" class="btn btn-secondary text-nowrap">Impor</button>
      </form>
    </div>
  </div>

  <table class="table table-bordered bg-white">
    <thead>
      <tr><th>Nama</th><th>No. HP</th><th>Sesi</th><th>Status QR</th><th></th></tr>
    </thead>
    <tbody>
      <% pesertaList.forEach(p => { %>
        <tr>
          <td><%= p.nama %></td>
          <td><%= p.no_hp %></td>
          <td><%= p.sesiList.map(s => s.nama).join(', ') %></td>
          <td>
            <% const badgeClass = { pending: 'bg-secondary', sent: 'bg-success', failed: 'bg-danger' }[p.status_kirim_qr] || 'bg-secondary'; %>
            <span class="badge <%= badgeClass %>"><%= p.status_kirim_qr %></span>
          </td>
          <td class="text-nowrap">
            <a href="/admin/peserta/<%= p.id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
            <form method="post" action="/admin/peserta/<%= p.id %>/resend-qr" class="d-inline">
              <button class="btn btn-sm btn-outline-warning" type="submit">Kirim Ulang</button>
            </form>
            <form method="post" action="/admin/peserta/<%= p.id %>/hapus" class="d-inline" onsubmit="return confirm('Hapus peserta ini?')">
              <button class="btn btn-sm btn-outline-danger" type="submit">Hapus</button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (pesertaList.length === 0) { %>
        <tr><td colspan="5" class="text-center text-muted">Belum ada peserta.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
<%- include('../../partials/foot') %>
