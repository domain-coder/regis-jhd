<%- include('../../partials/head', { title: title }) %>
<%- include('../../partials/navbar', { user }) %>
<div class="container" style="max-width: 600px;">
  <h3>Tambah Peserta Manual</h3>
  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
  <form method="post" action="/admin/peserta">
    <div class="mb-3">
      <label class="form-label">Nama</label>
      <input type="text" name="nama" class="form-control" value="<%= form.nama || '' %>" maxlength="150" required>
    </div>
    <div class="mb-3">
      <label class="form-label">No. HP/WA</label>
      <input
        type="tel"
        name="no_hp"
        class="form-control"
        value="<%= form.no_hp || '' %>"
        inputmode="numeric"
        pattern="[0-9\s-]{8,20}"
        title="Hanya angka, 8-15 digit"
        maxlength="20"
        required
      >
    </div>
    <div class="mb-3">
      <label class="form-label">Email (opsional)</label>
      <input type="email" name="email" class="form-control" value="<%= form.email || '' %>" maxlength="200">
    </div>
    <div class="mb-3">
      <label class="form-label">Institusi (opsional)</label>
      <input type="text" name="institusi" class="form-control" value="<%= form.institusi || '' %>" maxlength="200">
    </div>
    <label class="form-label">Sesi (boleh lebih dari satu, selama waktunya tidak bentrok)</label>
    <%- include('../../partials/sesi-picker', { sesiList }) %>

    <div class="form-check mb-3">
      <input class="form-check-input" type="checkbox" name="consent" id="consent" required>
      <label class="form-check-label small" for="consent">
        Peserta ini telah menyetujui data pribadinya (nama, no. HP/WA, email, institusi)
        digunakan untuk keperluan registrasi, pengiriman QR code, dan absensi event, sesuai
        UU No. 27 Tahun 2022 tentang Pelindungan Data Pribadi.
      </label>
    </div>

    <button type="submit" class="btn btn-primary">Simpan</button>
    <a href="/admin/peserta" class="btn btn-link">Batal</a>
  </form>
</div>
<script src="/js/sesi-picker.js"></script>
<%- include('../../partials/foot') %>
