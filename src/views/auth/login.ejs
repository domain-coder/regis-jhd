<%- include('../partials/head', { title: 'Login' }) %>
<div class="container text-center" style="max-width: 400px; margin-top: 6vh;">
  <img src="/img/dino-mascot.webp" alt="" class="brand-mascot mb-2" style="max-width: 90px;">
  <h3 class="brand-title mb-3">Login Panitia</h3>
  <div class="card jhd-card">
    <div class="card-body">
      <% if (error) { %>
        <div class="alert alert-danger py-2"><%= error %></div>
      <% } %>
      <form method="post" action="/login">
        <div class="mb-3">
          <label class="form-label">Username</label>
          <input type="text" name="username" class="form-control" required autofocus>
        </div>
        <div class="mb-3">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" required>
        </div>
        <% if (turnstileSiteKey) { %>
          <div class="cf-turnstile mb-3" data-sitekey="<%= turnstileSiteKey %>"></div>
        <% } %>

        <button type="submit" class="btn btn-primary w-100">Login</button>
      </form>
    </div>
  </div>
</div>
<% if (turnstileSiteKey) { %>
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<% } %>
<%- include('../partials/foot') %>
