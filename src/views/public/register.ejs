<%- include('../partials/head', { title: title }) %>
<div class="reg-layout">
  <img src="/img/dino-mascot.webp" alt="" class="reg-dino reg-dino-left d-none d-lg-block">
  <div class="reg-form-col container text-center">
    <img src="/img/brand-logo.webp" alt="Jagongan Hak Digital 2026 — Unmute Your Rights" style="max-width: 220px;" class="mb-2">
    <h3 class="brand-title mb-3">Registrasi Peserta</h3>
    <div class="card jhd-card text-start">
      <div class="card-body">
      <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
      <form method="post" action="/api/public/register">
        <div class="mb-3">
          <label class="form-label">Nama Lengkap</label>
          <input type="text" name="nama" class="form-control" value="<%= form.nama || '' %>" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Nomor HP/WA</label>
          <input type="text" name="no_hp" class="form-control" placeholder="08xxxxxxxxxx" value="<%= form.no_hp || '' %>" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Email (opsional)</label>
          <input type="email" name="email" class="form-control" value="<%= form.email || '' %>">
        </div>
        <div class="mb-3">
          <label class="form-label">Institusi (opsional)</label>
          <input type="text" name="institusi" class="form-control" value="<%= form.institusi || '' %>">
        </div>

        <label class="form-label">Pilih Sesi (boleh lebih dari satu, selama waktunya tidak bentrok)</label>
        <%- include('../partials/sesi-picker', { sesiList }) %>

        <div class="form-check mb-3">
          <input class="form-check-input" type="checkbox" name="consent" id="consent" required>
          <label class="form-check-label small" for="consent">
            Saya menyetujui data pribadi (nama, nomor HP/WA, email, institusi) yang saya berikan
            digunakan untuk keperluan registrasi, pengiriman QR code, dan absensi event Jagongan
            Hak Digital 2026, sesuai UU No. 27 Tahun 2022 tentang Pelindungan Data Pribadi.
          </label>
        </div>

        <% if (turnstileSiteKey) { %>
          <div class="cf-turnstile mb-3" data-sitekey="<%= turnstileSiteKey %>"></div>
        <% } %>

        <button type="submit" class="btn btn-primary w-100">Daftar</button>
      </form>
      </div>
    </div>
  </div>
  <img src="/img/dino-biru-small.webp" alt="" class="reg-dino reg-dino-right d-none d-lg-block">
</div>
<% if (turnstileSiteKey) { %>
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<% } %>
<script src="/js/sesi-picker.js"></script>
<%- include('../partials/foot') %>
