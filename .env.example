# Server
PORT=3000
NODE_ENV=development

# Session
SESSION_SECRET=ganti-dengan-string-acak-yang-panjang

# Database
DB_PATH=./data/jhd26.sqlite

# User super_admin default (dipakai oleh src/db/seed.js — WAJIB diganti setelah instalasi pertama)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ganti-password-ini
SEED_ADMIN_NAMA=Super Admin

# Cloudflare Turnstile (anti-bot di form registrasi publik) — ambil dari dashboard Cloudflare
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Pengiriman WhatsApp (Baileys) — kirim QR langsung dari server ini
# Nomor untuk pairing pertama kali (format 62xxxxxxxxxx). Kosongkan setelah
# berhasil pairing (sesi tersimpan di data/wa-auth/).
WA_PHONE_NUMBER=
# Sweep berkala jaring pengaman (ms) — proses ulang peserta yang masih pending.
# Sengaja tidak terlalu sering (default 5 menit): trigger instan sudah
# menangani kasus normal, sweep ini untuk flush penumpukan sekaligus kalau
# ada kegagalan/keterlambatan, bukan jalur utama pengiriman.
WA_POLL_INTERVAL_MS=300000
# Jeda antar pengiriman pesan WA (ms) — hindari rate-limit/flag dari WhatsApp
WA_SEND_DELAY_MS=4000
