# Server
PORT=3000
NODE_ENV=development

# Session
SESSION_SECRET=ganti-dengan-string-acak-yang-panjang

# Database
DB_PATH=./data/jhd26.sqlite

# User super_admin default (dipakai oleh src/db/seed.js — WAJIB diganti setelah instalasi pertama)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ganti-password-ini
SEED_ADMIN_NAMA=Super Admin

# Integrasi Hermes (machine-to-machine)
HERMES_API_KEY=ganti-dengan-api-key-acak-untuk-hermes

# Cloudflare Turnstile (anti-bot di form registrasi publik) — ambil dari dashboard Cloudflare
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
